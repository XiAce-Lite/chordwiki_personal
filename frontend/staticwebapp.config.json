{
    "responseOverrides": {
        "401": {
            "redirect": "/login",
            "statusCode": 302
        },
        "403": {
            "rewrite": "/403.html"
        }
    },
    "routes": [
        {
            "redirect": "/.auth/login/aad",
            "route": "/login"
        },
        {
            "redirect": "/.auth/logout",
            "route": "/logout"
        },
        {
            "allowedRoles": [
                "authenticated"
            ],
            "route": "/"
        },
        {
            "allowedRoles": [
                "authenticated"
            ],
            "route": "/song/*"
        },
        {
            "allowedRoles": [
                "editor"
            ],
            "route": "/edit/*"
        },
        {
            "allowedRoles": [
                "editor"
            ],
            "route": "/api/edit/*"
        }
    ]
}