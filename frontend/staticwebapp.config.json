{
  "auth": {
    "rolesSource": "/api/getRoles"
  },
  "responseOverrides": {
    "401": {
      "redirect": "/login",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/403.html"
    }
  },
  "routes": [
    {
      "route": "/login",
      "redirect": "/.auth/login/aad"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    },

    {
      "route": "/admin.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["admin"]
    },

    {
      "route": "/add.html",
      "redirect": "/edit.html?mode=add",
      "statusCode": 302
    },
    {
      "route": "/edit.html",
      "allowedRoles": ["editor", "admin"]
    },
    {
      "route": "/edit/*",
      "allowedRoles": ["editor", "admin"]
    },
    {
      "route": "/api/edit/*",
      "allowedRoles": ["editor", "admin"]
    },

    {
      "route": "/song.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/song/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/",
      "allowedRoles": ["authenticated"]
    }
  ]
}