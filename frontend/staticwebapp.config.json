{
  "responseOverrides": {
    "401": {
      "redirect": "/login",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/403.html"
    }
  },
  "routes": [
    {
      "route": "/login",
      "redirect": "/.auth/login/aad"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    },
    {
      "route": "/add.html",
      "redirect": "/edit.html?mode=add",
      "statusCode": 302
    },
    {
      "route": "/edit.html",
      "allowedRoles": ["editor"]
    },
    {
      "route": "/edit/*",
      "allowedRoles": ["editor"]
    },
    {
      "route": "/api/edit/*",
      "allowedRoles": ["editor"]
    },
    {
      "route": "/song.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/song/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/",
      "allowedRoles": ["authenticated"]
    }
  ]
}
